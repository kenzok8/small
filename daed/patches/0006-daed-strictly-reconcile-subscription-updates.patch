+		return nil, err
+	}
+	links, err := fetchLinks(m.Link)
+	if err != nil {
 		return nil, err
 	}
+	if err = updateSubscriptionTx(ctx, &m, subId, links); err != nil {
+		return nil, err
+	}
+	if err = config.ApplyIfRunning(ctx); err != nil {
+		return nil, fmt.Errorf("subscription updated but failed to apply runtime: %w", err)
+	}
 	return &m, nil
 }
 
